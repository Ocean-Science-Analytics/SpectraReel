shiny::runApp()
shiny::runApp()
library(readxl)
library(tidyr)
library(dplyr)
library(ggplot2)
df_raw <- read_excel("C:/Users/eferg/Documents/01_OSA/OSA_01_Active_Research/ManTech_WakeIsland/Reporting/Revised_Figures/Regional_MM_Likelihood.xlsx")
species_col <- names(df_raw)[1]
df_raw[[species_col]] <- trimws(as.character(df_raw[[species_col]]))
species_order <- c(
"Beaked whale species",
"Blue whale",
"Bryde's whale*",
"Delphinid species",
"Fin whale",
"Humpback whale**",
"Minke whale***",
"Sei whale",
"Sperm whale"
)
desired_map <- c(
"Delphinid species" = "Delphinid species",
"Beaked whale species" = "Beaked whale species",
"Blue whale" = "Blue whale",
"Bryde's whale" = "Bryde's whale*",
"Bryde's whale*" = "Bryde's whale*",
"Fin whale" = "Fin whale",
"Humpback whale" = "Humpback whale**",
"Humpback whale**" = "Humpback whale**",
"Minke whale" = "Minke whale***",
"Minke whale***" = "Minke whale***",
"Sei whale" = "Sei whale",
"Sperm whale" = "Sperm whale"
)
df_raw <- df_raw |>
filter(.data[[species_col]] %in% names(desired_map)) |>
mutate(Species = unname(desired_map[.data[[species_col]]])) |>
select(Species, everything(), -all_of(species_col))
month_order <- names(df_raw)[-1]
df <- df_raw |>
pivot_longer(cols = -Species, names_to = "Month", values_to = "Likelihood") |>
filter(!is.na(Likelihood)) |>
mutate(
Species = factor(Species, levels = rev(species_order)),
Month = factor(Month, levels = month_order),
Likelihood = factor(
Likelihood,
levels = c("Not Likely", "Low Likelihood", "Moderate Likelihood", "High Likelihood", "Unknown")
)
)
pal <- c(
"Not Likely" = "#D9F0D3",
"Low Likelihood" = "#A6DBA0",
"Moderate Likelihood" = "#5AAE61",
"High Likelihood" = "#1B7837",
"Unknown" = "#BDBDBD"
)
p <- ggplot(df, aes(x = Month, y = Species, fill = Likelihood)) +
geom_tile(color = "white", linewidth = 0.7, width = 0.98, height = 0.98) +
scale_fill_manual(
values = pal,
breaks = c("Not Likely", "Low Likelihood", "Moderate Likelihood", "High Likelihood", "Unknown"),
drop = FALSE,
name = NULL
) +
labs(title = "", x = NULL, y = NULL) +
theme_minimal(base_family = "DejaVu Sans") +
theme(
panel.grid = element_blank(),
axis.text.x = element_text(size = 16,angle = 45, hjust = 1, colour = "#222222"),
axis.text.y = element_text(size = 16, colour = "#222222"),
plot.title = element_text(hjust = 0.5, size = 15),
legend.position = "bottom",
legend.direction = "horizontal",
legend.title = element_blank(),
legend.text = element_text(size = 12),
legend.key.width = unit(1.4, "cm"),
legend.key.height = unit(0.4, "cm"),
plot.background = element_rect(fill = "white", colour = NA),
panel.background = element_rect(fill = "white", colour = NA),
plot.margin = margin(10, 10, 38, 10)
) +
guides(fill = guide_legend(nrow = 1, byrow = TRUE))
ggsave("C:/Users/eferg/Documents/01_OSA/OSA_01_Active_Research/ManTech_WakeIsland/Reporting/Revised_Figures/Regional_MM_Likelihood_Heatmap_reordered.png", p, width = 12, height = 6, dpi = 300, bg = "white")
print(p)
shiny::runApp()
runApp()
shiny::runApp()
runApp()
View(df)
runApp()
View(p)
